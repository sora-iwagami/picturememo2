
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.6.0/dist/leaflet.css"
   integrity="sha512-xwE/Az9zrjBIphAcBb3F6JVqxf46+CDLwfLMHloNu6KEQCAWi6HcDUbeOfBIptF7tcCzusKFjFw2yuvEpDL9wQ=="
   crossorigin=""/>
 <!-- Make sure you put this AFTER Leaflet's CSS -->
 <script src="https://unpkg.com/leaflet@1.6.0/dist/leaflet.js"
   integrity="sha512-gZwIG9x3wUXg2hdXF6+rVkLF/0Vi9U8D2Ntg4Ga5I5BZpVkVxlJWbSQtXPSiUTtC0TjtGOmxa1AJPuV0CPthew=="
   crossorigin=""></script>
<link rel="stylesheet" href="/assets/css/style.css">
<body>
    <div id="mapid"></div>
</body>


<script>
    const groupId = <%= @group.id %>;
    
const defaultIcon = L.icon({
  iconUrl: "https://esm.sh/leaflet@1.9.2/dist/images/marker-icon.png",
  iconRetinaUrl: "https://esm.sh/leaflet@1.9.2/dist/images/marker-icon-2x.png",
  shadowUrl: "https://esm.sh/leaflet@1.9.2/dist/images/marker-shadow.png",
  iconSize: [25, 41],
  iconAnchor: [12, 41],
  popupAnchor: [1, -34],
  tooltipAnchor: [16, -28],
  shadowSize: [41, 41],
});

  const icons = {
    1: L.icon({
      iconUrl: "https://esm.sh/leaflet@1.9.2/dist/images/marker-icon.png",
      iconRetinaUrl: "https://esm.sh/leaflet@1.9.2/dist/images/marker-icon-2x.png",
      shadowUrl: "https://esm.sh/leaflet@1.9.2/dist/images/marker-shadow.png",
      iconSize: [25, 41],
      iconAnchor: [12, 41],
      popupAnchor: [1, -34],
      tooltipAnchor: [16, -28],
      shadowSize: [41, 41],
      className: "icon-blue", // color_idが1の場合は青
    }),
    2: L.icon({
      iconUrl: "https://esm.sh/leaflet@1.9.2/dist/images/marker-icon.png",
      iconRetinaUrl: "https://esm.sh/leaflet@1.9.2/dist/images/marker-icon-2x.png",
      shadowUrl: "https://esm.sh/leaflet@1.9.2/dist/images/marker-shadow.png",
      iconSize: [25, 41],
      iconAnchor: [12, 41],
      popupAnchor: [1, -34],
      tooltipAnchor: [16, -28],
      shadowSize: [41, 41],
      className: "icon-red", // color_idが2の場合は赤
    }),
    3: L.icon({
      iconUrl: "https://esm.sh/leaflet@1.9.2/dist/images/marker-icon.png",
      iconRetinaUrl: "https://esm.sh/leaflet@1.9.2/dist/images/marker-icon-2x.png",
      shadowUrl: "https://esm.sh/leaflet@1.9.2/dist/images/marker-shadow.png",
      iconSize: [25, 41],
      iconAnchor: [12, 41],
      popupAnchor: [1, -34],
      tooltipAnchor: [16, -28],
      shadowSize: [41, 41],
      className: "icon-yellow", // color_idが3の場合は黄色
    }),
    // 必要に応じて他のcolor_idも追加
  };
    
var map = L.map('mapid', {
  zoom: 15,
});
var tileLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
  attribution: '© <a href="http://osm.org/copyright">OpenStreetMap</a> contributors, <a href="http://creativecommons.org/licenses/by-sa/2.0/">CC-BY-SA</a>',
});
tileLayer.addTo(map);

fetch(`/places?group_id=${groupId}`)
    .then(response => response.json())

        
    .then(data => {
    if (data.length > 0) {
        const lastPlace = data[data.length - 1];
        if (lastPlace.lat && lastPlace.lng) {
            map.setView([lastPlace.lat, lastPlace.lng], 15);
        } else {
            // 緯度経度がない場合にデフォルト位置
            map.setView([35.681236, 139.767125], 13); // 東京駅
        }
    } else {
        // データが空の場合にデフォルト位置
        map.setView([35.681236, 139.767125], 13); // 東京駅
    }

    data.forEach(place => {
        const userColorId = place.user && place.user.color_id ? place.user.color_id : null;
        const icon = icons[userColorId] || defaultIcon;

        if (place.lat && place.lng) {
            L.marker([place.lat, place.lng], { icon: icon }).addTo(map)
                .bindPopup(
                    place.place_name + '<img src="' + place.photo.url + '" alt="風景写真" style="width:100%;">'
                );
        }
    });
})

    .catch(error => console.error('Error loading the places:', error));


</script>
